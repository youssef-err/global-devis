# Sentry Error Tracking (optional — monitoring disabled if not set)
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=

# Public Supabase client configuration
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Google AdSense Publisher ID (e.g., "1234567890123456")
NEXT_PUBLIC_ADSENSE_PUB_ID=your-adsense-pub-id

# Optional application URL for production redirects
NEXT_PUBLIC_SITE_URL=https://your-domain.vercel.app

# Supabase Auth notes
# Site URL:
#   http://localhost:3000            (local)
#   https://your-domain.vercel.app   (production)
#
# Redirect URLs:
#   http://localhost:3000/auth/callback
#   https://your-domain.vercel.app/auth/callback
